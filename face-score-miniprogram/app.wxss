@keyframes fadeIn {
  from { opacity: 0; transform: translateY(30rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes scaleIn {
  from { opacity: 0; transform: scale(0.92); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

@keyframes float {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-10rpx); }
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

view, text, button, image, input, textarea, swiper, swiper-item {
  box-sizing: border-box;
}

page {
  font-family: "PingFang SC", "Helvetica Neue", Helvetica, Arial, sans-serif;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe4ec 100%);
  color: #333;
  min-height: 100vh;
  padding: 0;
}

.container {
  background: #FFFFFF;
  padding: 50rpx 40rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 126, 179, 0.15);
  text-align: center;
  max-width: 680rpx;
  margin: 30rpx auto;
  border: none;
  position: relative;
  overflow: hidden;
}

.container::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 200rpx;
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  border-radius: 24rpx 24rpx 0 0;
  z-index: 0;
}

h1 {
  color: #fff;
  margin-top: 0;
  font-size: 44rpx;
  margin-bottom: 12rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  position: relative;
  z-index: 1;
}

p {
  margin: 0 0 50rpx;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
  font-weight: 400;
  position: relative;
  z-index: 1;
}

button {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  color: white;
  border: none;
  padding: 28rpx 48rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  cursor: pointer;
  width: 100%;
  margin-bottom: 20rpx;
  box-shadow: 0 6rpx 20rpx rgba(255, 126, 179, 0.35);
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}

button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15), transparent);
  transition: left 0.6s;
}

button:active {
  transform: scale(0.98);
  box-shadow: 0 3rpx 10rpx rgba(255, 126, 179, 0.25);
}

button:active::before {
  left: 100%;
}

button:disabled {
  background: #f0f0f0;
  color: #ccc;
  box-shadow: none;
  transform: none;
}

#preview {
  max-width: 100%;
  max-height: 320rpx;
  margin: 24rpx auto;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 126, 179, 0.15);
  object-fit: cover;
  display: none;
  border: 4rpx solid #fff;
}

#preview.show {
  display: block;
}

#result {
  margin-top: 24rpx;
  font-size: 28rpx;
  font-weight: 400;
  min-height: 60rpx;
  color: #333;
  word-break: break-word;
  white-space: pre-wrap;
  text-align: left;
  padding: 30rpx;
  background: #fff5f7;
  border-radius: 16rpx;
  box-shadow: inset 0 2rpx 8rpx rgba(255, 126, 179, 0.08);
  border: 1rpx solid #ffe4ec;
  line-height: 1.7;
}

.text-center { text-align: center; }
.text-left { text-align: left; }
.mt-20 { margin-top: 20rpx; }
.mb-20 { margin-bottom: 20rpx; }
.flex { display: flex; }
.flex-col { flex-direction: column; }
.items-center { align-items: center; }
.justify-center { justify-content: center; }
.gap-10 { gap: 10rpx; }
.gap-20 { gap: 20rpx; }