.app-logo {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 30rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 179, 0.2);
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  position: relative;
  z-index: 1;
}

.mode-selector {
  display: flex;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 16rpx;
  padding: 8rpx;
  margin: 60rpx 0 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 126, 179, 0.1);
  position: relative;
  z-index: 1;
}

.mode-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666;
  transition: all 0.3s ease;
  font-weight: 500;
}

.mode-item.active {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 126, 179, 0.4);
  transform: translateY(-2rpx);
}

.buttons-container {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 30rpx;
  width: 100%;
  position: relative;
  z-index: 1;
}

.secondary-button {
  background: #fff !important;
  color: #ff6ec7 !important;
  border: 2rpx solid #ff6ec7 !important;
  box-shadow: 0 4rpx 16rpx rgba(255, 126, 179, 0.15) !important;
  border-radius: 44rpx !important;
}

.secondary-button:active {
  background: #fff5f7 !important;
  transform: scale(0.98) !important;
  box-shadow: 0 2rpx 8rpx rgba(255, 126, 179, 0.1) !important;
}

.main-button {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%) !important;
  color: white !important;
  border: none !important;
  border-radius: 44rpx !important;
  padding: 32rpx 48rpx !important;
  font-size: 32rpx !important;
  font-weight: 600 !important;
  box-shadow: 0 8rpx 28rpx rgba(255, 126, 179, 0.4) !important;
  transition: all 0.25s ease !important;
}

.main-button:active {
  transform: scale(0.98) !important;
  box-shadow: 0 4rpx 14rpx rgba(255, 126, 179, 0.3) !important;
}

.main-button:disabled {
  background: #f0f0f0 !important;
  color: #ccc !important;
  box-shadow: none !important;
}

.utility-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
  width: 100%;
}

.utility-buttons button {
  flex: 1;
  padding: 20rpx 24rpx;
  font-size: 26rpx;
  margin-bottom: 0;
}

.preview-container {
  position: relative;
  margin: 30rpx 0;
  border-radius: 16rpx;
  overflow: hidden;
  background: #fff5f7;
  padding: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 126, 179, 0.1);
  border: 1rpx solid #ffe4ec;
  position: relative;
  z-index: 1;
}

.clear-preview-btn {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #999;
  border: none;
  border-radius: 50%;
  font-size: 32rpx;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 126, 179, 0.15);
  transition: all 0.2s ease;
  z-index: 10;
  padding: 0;
}

.clear-preview-btn:active {
  background: #fff;
  color: #666;
  transform: scale(0.9);
}

.result-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 36rpx;
  margin-top: 30rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 126, 179, 0.1);
  border: 1rpx solid #ffe4ec;
  animation: fadeIn 0.4s ease-out;
  position: relative;
  z-index: 1;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(20rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.score-number {
  font-size: 52rpx;
  font-weight: 700;
  color: #ff6ec7;
  margin: 10rpx 0;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.result-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
  margin-top: 16rpx;
  white-space: pre-wrap;
  text-align: left;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 50rpx;
  gap: 24rpx;
  position: relative;
  z-index: 1;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #ffe4ec;
  border-top: 4rpx solid #ff6ec7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #666;
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 30rpx;
}

.action-button {
  flex: 1;
  background: #fff5f7;
  color: #666;
  font-size: 28rpx;
  padding: 24rpx;
  border-radius: 12rpx;
  box-shadow: none;
  border: 1rpx solid #ffe4ec;
  margin-bottom: 0;
  font-weight: 500;
}

.action-button.primary {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  color: white;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 126, 179, 0.4);
}

.action-button:active {
  opacity: 0.9;
  transform: scale(0.96);
}

.toast {
  background: rgba(0, 0, 0, 0.85);
  border-radius: 12rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 30rpx;
  color: #ccc;
  text-align: center;
  position: relative;
  z-index: 1;
}

.empty-state-icon {
  font-size: 60rpx;
  opacity: 0.5;
  margin-bottom: 16rpx;
}

.empty-state-text {
  font-size: 24rpx;
  line-height: 1.5;
  color: #bbb;
}

.couple-preview-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  margin: 30rpx 0;
  position: relative;
  z-index: 1;
  background: #fff5f7;
  border-radius: 16rpx;
  padding: 32rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 126, 179, 0.1);
  border: 1rpx solid #ffe4ec;
}

.couple-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.couple-avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 24rpx rgba(255, 126, 179, 0.2);
  border: 4rpx solid #fff;
}

.couple-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.couple-clear-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 44rpx;
  height: 44rpx;
  background: #fff;
  color: #999;
  border: 2rpx solid #ffe4ec;
  border-radius: 50%;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(255, 126, 179, 0.2);
  z-index: 10;
  padding: 0;
}

.couple-clear-btn:active {
  background: #ffe4ec;
  color: #ff6ec7;
  transform: scale(0.9);
}

.couple-avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff5f7 0%, #ffe4ec 100%);
  border: 3rpx dashed #ffc0d0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.3s ease;
  box-shadow: 0 4rpx 16rpx rgba(255, 126, 179, 0.1);
}

.couple-avatar-placeholder:active {
  background: #ffe4ec;
  border-color: #ff6ec7;
  transform: scale(1.05);
}

.avatar-icon {
  font-size: 48rpx;
  opacity: 0.6;
}

.avatar-label {
  font-size: 22rpx;
  color: #999;
}

.couple-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.couple-heart {
  font-size: 48rpx;
  animation: pulseHeart 1.5s ease-in-out infinite;
}

@keyframes pulseHeart {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.2); opacity: 1; }
}

.security-badge {
  position: absolute;
  bottom: 16rpx;
  left: 16rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.security-badge.security-passed {
  background: rgba(76, 175, 80, 0.9);
  color: #fff;
}

.security-badge.security-rejected {
  background: rgba(244, 67, 54, 0.9);
  color: #fff;
}

.security-icon {
  font-size: 20rpx;
}

.security-text {
  font-size: 22rpx;
}

.couple-security-badge {
  position: absolute;
  bottom: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: #fff;
  font-weight: 600;
  border: 3rpx solid #fff;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.couple-security-badge.security-passed {
  background: #4caf50;
}

.couple-security-badge.security-rejected {
  background: #f44336;
}

.couple-security-text {
  font-size: 22rpx;
  font-weight: 500;
  margin-top: 4rpx;
}

.couple-security-text.security-passed {
  color: #4caf50;
}

.couple-security-text.security-rejected {
  color: #f44336;
}

.checking-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #ffe4ec;
  border-top: 3rpx solid #ff6ec7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@media (min-width: 750rpx) {
  .container {
    max-width: 640rpx;
    padding: 60rpx 50rpx;
    margin: 40rpx auto;
  }
}

@media (prefers-color-scheme: dark) {
  page {
    background: linear-gradient(135deg, #2d1f2d 0%, #2a1a2a 100%);
  }
  
  .container {
    background: #3d2a3d;
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  }
  
  .container::before {
    background: linear-gradient(135deg, #cc5c8a 0%, #b35075 100%);
  }
  
  h1 {
    color: #fff;
  }
  
  p {
    color: rgba(255, 255, 255, 0.7);
  }
  
  button {
    background: linear-gradient(135deg, #cc5c8a 0%, #b35075 100%);
    box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.3);
  }
  
  button:active {
    box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.4);
  }
  
  .mode-selector {
    background: rgba(255, 255, 255, 0.08);
  }
  
  .mode-item {
    color: #999;
  }
  
  .mode-item.active {
    background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
    color: #fff;
  }
  
  .result-card {
    background: #3d2a3d;
    border-color: #5c3d5c;
  }
  
  .result-title {
    color: #fff;
  }
  
  .result-content {
    color: #ccc;
  }
  
  .score-number {
    color: #ff9fbd;
  }
  
  .preview-container {
    background: #3d2a3d;
    border-color: #5c3d5c;
  }
  
  .secondary-button {
    background: #3d2a3d !important;
    color: #ff9fbd !important;
    border-color: #ff9fbd !important;
  }
  
  .action-button {
    background: #3d2a3d;
    color: #ccc;
    border-color: #5c3d5c;
  }
  
  .action-button.primary {
    background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  }
  
  .empty-state-text {
    color: #666;
  }
  
  .couple-preview-container {
    background: #3d2a3d;
    border-color: #5c3d5c;
  }
  
  .couple-avatar-placeholder {
    background: #3d2a3d;
    border-color: #5c3d5c;
  }
  
  .couple-name {
    color: #999;
  }
  
  #result {
    background: #3d2a3d;
    border-color: #5c3d5c;
    color: #ccc;
  }
}