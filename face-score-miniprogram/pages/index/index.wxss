.header {
  text-align: center;
  padding: 20rpx 0 40rpx;
  animation: fadeInUp 0.6s ease-out;
}

.logo-wrap {
  width: 140rpx;
  height: 140rpx;
  margin: 0 auto 24rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  box-shadow: 0 8rpx 32rpx rgba(255, 110, 199, 0.15);
  border: 3rpx solid rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  animation: float 3s ease-in-out infinite;
}

.app-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
}

.app-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
  letter-spacing: 4rpx;
}

.app-subtitle {
  font-size: 26rpx;
  color: #999;
  line-height: 1.5;
}

.mode-selector {
  display: flex;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  border-radius: 24rpx;
  padding: 8rpx;
  margin: 0 0 40rpx;
  box-shadow: 0 4rpx 20rpx rgba(255, 110, 199, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.5);
  animation: fadeInUp 0.6s ease-out 0.1s both;
}

.mode-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 12rpx;
  border-radius: 20rpx;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.mode-icon {
  font-size: 40rpx;
  margin-bottom: 8rpx;
  transition: transform 0.35s cubic-bezier(0.4, 0, 0.2, 1);
}

.mode-text {
  font-size: 24rpx;
  color: #666;
  font-weight: 500;
  transition: color 0.3s ease;
}

.mode-item.active {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  box-shadow: 0 6rpx 24rpx rgba(255, 110, 199, 0.35);
  transform: translateY(-4rpx);
}

.mode-item.active .mode-icon {
  transform: scale(1.2);
}

.mode-item.active .mode-text {
  color: #fff;
}

.preview-container {
  position: relative;
  margin: 0 0 40rpx;
  border-radius: 24rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.7);
  backdrop-filter: blur(20rpx);
  padding: 16rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 110, 199, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  animation: fadeInUp 0.6s ease-out;
}

.preview-image {
  width: 100%;
  max-height: 400rpx;
  border-radius: 20rpx;
  object-fit: contain;
}

.clear-preview-btn {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #999;
  border-radius: 50%;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(255, 110, 199, 0.15);
  transition: all 0.25s ease;
}

.clear-preview-btn:active {
  background: #fff;
  color: #ff6ec7;
  transform: scale(0.9);
}

.couple-preview-container {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  margin: 0 0 40rpx;
  animation: fadeInUp 0.6s ease-out;
}

.couple-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.couple-avatar-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  overflow: hidden;
  box-shadow: 0 8rpx 28rpx rgba(255, 110, 199, 0.18);
  border: 4rpx solid rgba(255, 255, 255, 0.8);
}

.couple-avatar {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.couple-clear-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.95);
  color: #999;
  border-radius: 50%;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(255, 110, 199, 0.15);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  transition: all 0.25s ease;
}

.couple-clear-btn:active {
  background: #ffe4ec;
  color: #ff6ec7;
  transform: scale(0.9);
}

.couple-avatar-placeholder {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.6);
  backdrop-filter: blur(10rpx);
  border: 3rpx dashed rgba(255, 110, 199, 0.3);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  box-shadow: 0 4rpx 16rpx rgba(255, 110, 199, 0.08);
}

.couple-avatar-placeholder:active {
  background: rgba(255, 255, 255, 0.8);
  border-color: rgba(255, 110, 199, 0.5);
  transform: scale(1.05);
}

.avatar-icon {
  font-size: 52rpx;
  opacity: 0.5;
}

.avatar-label {
  font-size: 22rpx;
  color: #999;
}

.couple-name {
  font-size: 26rpx;
  color: #666;
  font-weight: 500;
}

.couple-heart {
  font-size: 48rpx;
  animation: pulse 2s ease-in-out infinite;
}

.couple-security-badge {
  position: absolute;
  bottom: -10rpx;
  right: -10rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  color: #fff;
  font-weight: 600;
  border: 4rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.couple-security-badge.security-passed {
  background: linear-gradient(135deg, #4caf50 0%, #45a049 100%);
}

.couple-security-badge.security-rejected {
  background: linear-gradient(135deg, #f44336 0%, #da190b 100%);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  color: #ccc;
  text-align: center;
  animation: fadeInUp 0.6s ease-out;
}

.empty-state-icon {
  font-size: 72rpx;
  opacity: 0.4;
  margin-bottom: 20rpx;
  animation: float 4s ease-in-out infinite;
}

.empty-state-text {
  font-size: 26rpx;
  line-height: 1.6;
  color: #bbb;
}

.main-action {
  margin-top: 20rpx;
  animation: fadeInUp 0.6s ease-out 0.2s both;
}

.main-button {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  color: #fff;
  border-radius: 48rpx;
  padding: 34rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 10rpx 36rpx rgba(255, 110, 199, 0.4);
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  position: relative;
  overflow: hidden;
}

.main-button::before {
  content: '';
  position: absolute;
  top: 0;
  left: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.18), transparent);
  transition: left 0.6s;
}

.main-button:active {
  transform: scale(0.98);
  box-shadow: 0 6rpx 20rpx rgba(255, 110, 199, 0.3);
}

.main-button:active::before {
  left: 100%;
}

.main-button[disabled] {
  background: #f0f0f0;
  color: #ccc;
  box-shadow: none;
  transform: none;
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 30rpx;
  gap: 24rpx;
}

.loading-spinner {
  width: 72rpx;
  height: 72rpx;
  border: 4rpx solid rgba(255, 110, 199, 0.1);
  border-top: 4rpx solid #ff6ec7;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  0% { transform: rotate(0deg); }
  100% { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.result-card {
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(20rpx);
  border-radius: 32rpx;
  padding: 36rpx;
  margin-top: 40rpx;
  box-shadow: 0 8rpx 32rpx rgba(255, 110, 199, 0.1);
  border: 1rpx solid rgba(255, 255, 255, 0.6);
  animation: fadeInUp 0.5s ease-out;
}

.result-header {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.result-content {
  font-size: 28rpx;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
  text-align: left;
  padding: 24rpx;
  background: rgba(255, 245, 247, 0.8);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 110, 199, 0.1);
}

.action-buttons {
  display: flex;
  gap: 20rpx;
  margin-top: 32rpx;
}

.action-button {
  flex: 1;
  background: rgba(255, 245, 247, 0.8);
  color: #666;
  font-size: 28rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  text-align: center;
  border: 1rpx solid rgba(255, 110, 199, 0.15);
  font-weight: 500;
  transition: all 0.25s ease;
}

.action-button.primary {
  background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  color: #fff;
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(255, 110, 199, 0.35);
}

.action-button:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.checking-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 3rpx solid rgba(255, 110, 199, 0.2);
  border-top: 3rpx solid #ff6ec7;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@media (prefers-color-scheme: dark) {
  page {
    background: linear-gradient(180deg, #2d1f2d 0%, #2a1a2a 60%, #251525 100%);
  }

  .app-title {
    color: #fff;
  }

  .app-subtitle {
    color: rgba(255, 255, 255, 0.6);
  }

  .logo-wrap {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.3);
  }

  .mode-selector {
    background: rgba(255, 255, 255, 0.08);
    border-color: rgba(255, 255, 255, 0.1);
    box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
  }

  .mode-text {
    color: #999;
  }

  .mode-item.active {
    box-shadow: 0 6rpx 24rpx rgba(255, 110, 199, 0.25);
  }

  .preview-container {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .clear-preview-btn {
    background: rgba(255, 255, 255, 0.15);
    color: #ccc;
  }

  .couple-avatar-wrap {
    border-color: rgba(255, 255, 255, 0.4);
    box-shadow: 0 8rpx 28rpx rgba(0, 0, 0, 0.3);
  }

  .couple-avatar-placeholder {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 110, 199, 0.2);
  }

  .couple-name {
    color: #999;
  }

  .empty-state-text {
    color: #666;
  }

  .result-card {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .result-title {
    color: #fff;
  }

  .result-content {
    color: #ccc;
    background: rgba(255, 255, 255, 0.04);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .action-button {
    background: rgba(255, 255, 255, 0.06);
    color: #ccc;
    border-color: rgba(255, 255, 255, 0.1);
  }

  .action-button.primary {
    background: linear-gradient(135deg, #ff7eb3 0%, #ff6ec7 100%);
  }
}
