<view class="container">
  <view class="header">
    <view class="logo-wrap">
      <image class="app-logo" src="/images/logo.png" mode="aspectFit"></image>
    </view>
    <view class="app-title">萌牛测颜</view>
    <view class="app-subtitle">上传照片，发现你的美丽秘密</view>
  </view>

  <view class="mode-selector">
    <view class="mode-item {{mode === 'score' ? 'active' : ''}}" bindtap="switchMode" data-mode="score">
      <view class="mode-icon">💖</view>
      <view class="mode-text">颜值评分</view>
    </view>
    <view class="mode-item {{mode === 'fortune' ? 'active' : ''}}" bindtap="switchMode" data-mode="fortune">
      <view class="mode-icon">✨</view>
      <view class="mode-text">气质解读</view>
    </view>
    <view class="mode-item {{mode === 'couple' ? 'active' : ''}}" bindtap="switchMode" data-mode="couple">
      <view class="mode-icon">💕</view>
      <view class="mode-text">CP匹配度</view>
    </view>
  </view>

  <view class="preview-container" wx:if="{{previewShow && mode !== 'couple'}}">
    <image class="preview-image" src="{{previewUrl}}" mode="aspectFit"></image>
    <view class="clear-preview-btn" bindtap="clearPreview">×</view>
  </view>

  <view class="couple-preview-container" wx:if="{{mode === 'couple'}}">
    <view class="couple-card">
      <view class="couple-avatar-wrap" wx:if="{{previewUrlA}}">
        <image class="couple-avatar" src="{{previewUrlA}}" mode="aspectFill"></image>
        <view class="couple-clear-btn" bindtap="clearPreviewA">×</view>
        <view class="couple-security-badge {{securityStatusA === 'passed' ? 'security-passed' : (securityStatusA === 'rejected' ? 'security-rejected' : '')}}" wx:if="{{securityStatusA}}">
          <text>{{securityStatusA === 'passed' ? '✓' : '✗'}}</text>
        </view>
      </view>
      <view class="couple-avatar-placeholder" wx:else bindtap="chooseImageA">
        <view class="avatar-icon">{{checkingA ? '' : '👧'}}</view>
        <view class="avatar-label">{{checkingA ? '安全检查中...' : '我的照片'}}</view>
        <view class="checking-spinner" wx:if="{{checkingA}}"></view>
      </view>
      <view class="couple-name">我</view>
    </view>

    <view class="couple-heart">💕</view>

    <view class="couple-card">
      <view class="couple-avatar-wrap" wx:if="{{previewUrlB}}">
        <image class="couple-avatar" src="{{previewUrlB}}" mode="aspectFill"></image>
        <view class="couple-clear-btn" bindtap="clearPreviewB">×</view>
        <view class="couple-security-badge {{securityStatusB === 'passed' ? 'security-passed' : (securityStatusB === 'rejected' ? 'security-rejected' : '')}}" wx:if="{{securityStatusB}}">
          <text>{{securityStatusB === 'passed' ? '✓' : '✗'}}</text>
        </view>
      </view>
      <view class="couple-avatar-placeholder" wx:else bindtap="chooseImageB">
        <view class="avatar-icon">{{checkingB ? '' : '👦'}}</view>
        <view class="avatar-label">{{checkingB ? '安全检查中...' : 'TA的照片'}}</view>
        <view class="checking-spinner" wx:if="{{checkingB}}"></view>
      </view>
      <view class="couple-name">TA</view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{!previewShow && !previewUrlA && !previewUrlB}}">
    <view class="empty-state-icon">{{mode === 'score' ? '💖' : (mode === 'fortune' ? '✨' : '💕')}}</view>
    <view class="empty-state-text">
      {{mode === 'score' ? '上传美照\n看看你的颜值能打多少分' : (mode === 'fortune' ? '上传照片\n解锁你的专属气质密码' : '上传两张照片\n测测你们的甜蜜指数')}}
    </view>
  </view>

  <view class="main-action">
    <view bindtap="handleMainAction" class="main-button" disabled="{{submitting}}">
      {{mainButtonText}}
    </view>
  </view>

  <view class="loading-container" wx:if="{{submitting}}">
    <view class="loading-spinner"></view>
    <view class="loading-text">{{mode === 'couple' ? '正在计算缘分指数...' : '正在分析面部特征...'}}</view>
  </view>

  <view wx:if="{{result && !submitting}}" class="result-card">
    <view class="result-header">
      <view class="result-title">{{mode === 'score' ? '💖 颜值评分报告' : (mode === 'fortune' ? '✨ 气质分析报告' : '💕 缘分匹配报告')}}</view>
    </view>
    <view class="result-content">{{result}}</view>
    
    <view class="action-buttons">
      <view class="action-button primary" bindtap="saveResult">生成分享图片</view>
    </view>
  </view>

  <canvas type="2d" id="shareCanvas" style="position: fixed; left: -9999px; top: 0; width: 375px; height: 600px;"></canvas>
</view>
